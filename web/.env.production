# Variables de Entorno para Producción
# Actualiza estos valores según tu servidor de producción

# URL del backend API
VITE_API_BASE_URL=https://api.dermacheck.com

# Versión de la aplicación
VITE_APP_VERSION=1.0.0

# Entorno
VITE_ENV=production

# Habilitar analytics (opcional)
VITE_ENABLE_ANALYTICS=false

# Timeout para requests (en milisegundos)
VITE_API_TIMEOUT=30000

# Nivel de logs (error, warn, info, debug)
VITE_LOG_LEVEL=error
