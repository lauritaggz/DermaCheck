# Variables de entorno para DermaCheck Web
# Copia este archivo a .env y actualiza los valores según tu entorno

# URL del backend API
# - Desarrollo local: http://localhost:8000
# - Red local: http://192.168.x.x:8000
# - Producción: https://api.dermacheck.com
VITE_API_BASE_URL=http://localhost:8000

# Versión de la aplicación
VITE_APP_VERSION=1.0.0

# Entorno (development, staging, production)
VITE_ENV=development

# Habilitar analytics (opcional)
VITE_ENABLE_ANALYTICS=false

# Timeout para requests API (en milisegundos)
VITE_API_TIMEOUT=30000

# Nivel de logs (error, warn, info, debug)
VITE_LOG_LEVEL=debug
