{
  "expo": {
    "name": "DermaCheck",
    "slug": "dermacheck",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2C6E7E"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ],
      "package": "com.jrvera.dermacheck"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "DermaCheck necesita acceso a su galería para analizar una foto del rostro.",
          "cameraPermission": "DermaCheck requiere la cámara para capturar una foto del rostro con fines de análisis clínico."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "DermaCheck utiliza la cámara para mostrarle una guía y capturar el rostro con fines de análisis dermatológico profesional."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0b4fc410-db6f-4840-888f-cfe21b6e71f8"
      }
    }
  }
}
