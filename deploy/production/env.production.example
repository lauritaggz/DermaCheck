# Copiar en el servidor a deploy/production/.env (no subir .env a Git).
# MySQL persiste en deploy/production/data/mysql/ · subidas en deploy/production/data/uploads/
# docker compose --env-file deploy/production/.env -f deploy/production/docker-compose.prod.yml up -d --build
#
# Genera contraseñas fuertes para MySQL, p. ej.: openssl rand -base64 24

MYSQL_DATABASE=dermacheck
MYSQL_USER=dermacheck_prod_user
MYSQL_PASSWORD=cambiar_por_clave_larga_y_unica
MYSQL_ROOT_PASSWORD=cambiar_otra_clave_root_distinta

# Debe coincidir con MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE / host db (nombre del servicio en compose)
DATABASE_URL=mysql+pymysql://dermacheck_prod_user:cambiar_por_clave_larga_y_unica@db:3306/dermacheck?charset=utf8mb4

# URL del Frontend en Netlify para configurar CORS
FRONTEND_NETLIFY_URL=https://tu-sitio-dermacheck.netlify.app
