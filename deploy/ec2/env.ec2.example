# Copiar a deploy/ec2/.env en el servidor (no subir a Git).
# cp deploy/ec2/env.ec2.example deploy/ec2/.env
#
# Generar contraseñas: openssl rand -base64 24

TZ=America/Santiago

# DNS público de la instancia EC2 (sin barra final)
EC2_PUBLIC_URL=ec2-34-230-43-210.compute-1.amazonaws.com

API_HOST_PORT=8000
WEB_HOST_PORT=80

MYSQL_DATABASE=dermacheck
MYSQL_USER=dermacheck_prod
MYSQL_PASSWORD=cambiar_por_clave_larga
MYSQL_ROOT_PASSWORD=cambiar_otra_clave_root

DATABASE_URL=mysql+pymysql://dermacheck_prod:cambiar_por_clave_larga@db:3306/dermacheck?charset=utf8mb4

# CORS: incluir la URL pública del frontend y Netlify si aplica
CORS_ORIGINS=http://ec2-34-230-43-210.compute-1.amazonaws.com,https://ec2-34-230-43-210.compute-1.amazonaws.com,http://34.230.43.210,https://34.230.43.210,https://dermachecklandingpage.netlify.app

# URL pública del backend usada al compilar el frontend (mismo dominio que la web)
VITE_API_BASE_URL=https://dermacheck2.duckdns.org

# Correo (SMTP Gmail u otro proveedor)
EMAIL_ENABLED=true
EMAIL_PROVIDER=smtp
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=tu-cuenta@gmail.com
EMAIL_SMTP_PASSWORD=contraseña_de_aplicacion
EMAIL_SMTP_USE_TLS=true
EMAIL_FROM=DermaCheck <tu-cuenta@gmail.com>
EMAIL_REPLY_TO=tu-cuenta@gmail.com
EMAIL_RATE_LIMIT_PER_MINUTE=10

ANALYSIS_QUEUE_MAX_SIZE=10
ANALYSIS_MAX_CONCURRENT=1
ANALYSIS_JOB_TTL_SECONDS=3600
ANALYSIS_JOB_POLL_INTERVAL_HINT=1.5
PRODUCT_SEARCH_ENABLE_PLAYWRIGHT=true
