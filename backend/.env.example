# SQLite (por defecto): un archivo `dermacheck.db` en esta carpeta. No instales MySQL.
DATABASE_URL=sqlite:///./dermacheck.db

# Expo usa EXPO_PUBLIC_API_BASE_URL en el .env de la RAÍZ del monorepo, no en backend/.
# Si más adelante usas MySQL en localhost, descomenta y ajusta:
# DATABASE_URL=mysql+pymysql://usuario:clave@127.0.0.1:3306/dermacheck?charset=utf8mb4

# HU22 — búsqueda de productos (scraper Farmacompara)
# PRODUCT_SEARCH_CACHE_TTL_HOURS=12
# PRODUCT_SEARCH_MAX_RESULTS=5
# PRODUCT_SEARCH_MIN_RESULTS=3
# PRODUCT_SEARCH_ENABLE_PLAYWRIGHT=true
