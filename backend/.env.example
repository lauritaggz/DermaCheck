# SQLite (por defecto): un archivo `dermacheck.db` en esta carpeta. No instales MySQL.
DATABASE_URL=sqlite:///./dermacheck.db

# Zona horaria (correos, logs). En Docker usar America/Santiago.
TZ=America/Santiago

# Expo usa EXPO_PUBLIC_API_BASE_URL en el .env de la RAÍZ del monorepo, no en backend/.
# Si más adelante usas MySQL en localhost, descomenta y ajusta:
# DATABASE_URL=mysql+pymysql://usuario:clave@127.0.0.1:3306/dermacheck?charset=utf8mb4

# Umbrales YOLO (0.0–1.0). Reiniciar uvicorn tras cambiar.
# DERMACHECK_DERM_CONF=0.25
# DERMACHECK_EXPRESSION_LINES_CONF=0.65

# HU22 — búsqueda de productos (scraper Farmacompara)
# PRODUCT_SEARCH_CACHE_TTL_HOURS=12
# PRODUCT_SEARCH_MAX_RESULTS=5
# PRODUCT_SEARCH_MIN_RESULTS=3
# PRODUCT_SEARCH_ENABLE_PLAYWRIGHT=true

# Envío de resumen por correo (POST /api/v1/analysis/send-summary-email)
# EMAIL_ENABLED=true
# EMAIL_PROVIDER=resend
# EMAIL_API_KEY=re_xxxxxxxx
# EMAIL_FROM=DermaCheck <no-reply@dermacheck.cl>
# EMAIL_REPLY_TO=
# EMAIL_RATE_LIMIT_PER_MINUTE=5
#
# Alternativa SMTP (EMAIL_PROVIDER=smtp) — útil en local con Gmail:
# 1. Activa verificación en 2 pasos en la cuenta Google
# 2. Crea una «Contraseña de aplicación» en https://myaccount.google.com/apppasswords
# 3. Copia estos valores en backend/.env (ese archivo NO se sube a Git)
# EMAIL_ENABLED=true
# EMAIL_PROVIDER=smtp
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=tu-cuenta@gmail.com
# EMAIL_SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# EMAIL_SMTP_USE_TLS=true
# EMAIL_FROM=DermaCheck <tu-cuenta@gmail.com>
# EMAIL_REPLY_TO=tu-cuenta@gmail.com

# Cola de análisis facial (POST /api/v1/analysis/jobs — requiere 1 proceso uvicorn)
# ANALYSIS_QUEUE_MAX_SIZE=10
# ANALYSIS_MAX_CONCURRENT=1
# ANALYSIS_JOB_TTL_SECONDS=3600
# ANALYSIS_JOB_POLL_INTERVAL_HINT=1.5
