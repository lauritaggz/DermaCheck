# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Backend Python
backend/dermacheck.db
backend/*.db
backend/venv/
backend/uploads/
# Imágenes de entrenamiento (consentimiento) y cola temporal de jobs — solo runtime local
backend/storage/
# Pesos YOLO locales (no versionar): best.pt + HU17 best_wrinkle_yolov8m.pt
backend/ml_models/*.pt
backend/ml_models/best_wrinkle_yolov8m.pt
backend/logs/
backend/**/__pycache__/
backend/**/*.pyc
backend/.env

# Web app (Vite + React)
web/dist/
web/node_modules/
web/.env
web/.env.local

# Deploy
deploy/production/.env
deploy/production/.env.*
deploy/production/data/mysql/*
!deploy/production/data/mysql/.gitkeep
deploy/production/data/uploads/*
!deploy/production/data/uploads/.gitkeep

# macOS
.DS_Store
*.pem

# TypeScript
*.tsbuildinfo

# Logs
npm-debug.*
yarn-debug.*
yarn-error.*
node_modules
